# =====================================================================
# KIRA — Variables de entorno
# Copiar a .env y llenar valores reales. NO commitear .env.
# =====================================================================

# ---------- Servidor ----------
PORT=3000
NODE_ENV=development
TZ=America/Lima

# ---------- Supabase ----------
# Project Settings -> API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ---------- Evolution API (WhatsApp) ----------
# Misma instancia que Eli, pero con un instance_name distinto
EVOLUTION_API_URL=https://evolution.tu-dominio.com
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE_NAME=kira

# JID del grupo de WhatsApp del equipo de marketing (se captura solo)
# Formato: 120363XXXXXXXXX@g.us
GROUP_JID=

# ---------- OpenAI ----------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1

# ---------- Hoja de productividad de Luisa (Apps Script) ----------
# URL del Apps Script desplegado como Web App
SHEETS_WEBHOOK_URL=
# Mismo secret que pusiste en Script Properties como KIRA_SECRET
SHEETS_WEBHOOK_SECRET=

# ---------- Webhook ----------
# Token compartido para validar que los webhooks vengan de Evolution
WEBHOOK_SECRET=

# =====================================================================
# MIA — Módulo de la clínica privada de Mirai
# Credenciales SEPARADAS de las de la empresa: la cuenta personal de
# Mirai paga su OpenAI y vive en su Supabase propio. Aislamiento total.
# =====================================================================

# ---------- Supabase de Mirai (proyecto nuevo, NO la empresa) ----------
MIRAI_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
MIRAI_SUPABASE_SERVICE_ROLE_KEY=

# ---------- OpenAI de Mirai (cuenta personal) ----------
MIRAI_OPENAI_API_KEY=
MIRAI_OPENAI_MODEL=gpt-4o-mini

# ---------- Número personal de Mirai (autoriza comandos /paciente) ----------
# Formato E.164 sin "+" ni espacios. Ej: 51904301391
MIRAI_PERSONAL_PHONE=

# ---------- Operadores autorizados (asistente, recepcionista, etc.) ----------
# Lista separada por coma de números (mismo formato que MIRAI_PERSONAL_PHONE)
# que pueden enviar NOTAS DE LEADS directo a kiramkt — Mia hace intake auto.
# Estos números NO pueden ejecutar comandos administrativos (/paciente, /quitar
# /notas) — esos quedan solo para MIRAI_PERSONAL_PHONE.
# Ej: 51999888777,51988777666
MIA_OPERATOR_PHONES=

# ---------- Modo silencio inteligente:
# - La apertura inicial de Mirai (su saludo manual a un paciente nuevo) NO
#   silencia a Mia. Mia toma el control del triage de inmediato.
# - Si Mirai vuelve a escribir manualmente EN MEDIO de un flujo donde Mia
#   ya respondió, Mia se calla por X minutos para no interrumpir.
# Default = 5. Pon 0 para desactivar completamente el silencio.
MIA_SILENCE_AFTER_MIRAI_MINUTES=5

# ---------- Debounce de mensajes entrantes (ms):
# Mia espera N ms antes de procesar un mensaje, agrupando los que lleguen
# del mismo paciente en ese intervalo. Evita respuestas a cada mensaje
# suelto cuando el paciente escribe en rafagas.
# Default = 10000 (10 segundos).
MIA_DEBOUNCE_MS=10000

# ---------- Imágenes que Mia puede enviar ----------
# URLs públicas a las imágenes que Mia incluye en el campo "imagenes" de
# su respuesta. Si no están definidas, Mia envía el texto pero no la imagen.
# Foto del consultorio (Avenida Los Tallanes, Piura)
MIA_IMG_FOTO_SEDE=
